{
  "name": "arti-cli",
  "version": "0.2.0",
  "description": "ARTI 智能投研 CLI 工具 — OpenBB 驱动的股票分析命令行",
  "type": "module",
  "bin": {
    "arti": "./dist/index.js",
    "arti-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/mcp-server.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js"
  },
  "keywords": [
    "cli",
    "stock",
    "finance",
    "ai",
    "investment",
    "research",
    "trading"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
