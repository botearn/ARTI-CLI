{
  "name": "arti-cli",
  "version": "0.3.4",
  "description": "ARTI 智能投研 CLI 工具 — 聊天 / 快速扫描 / 全景 / 深度研报",
  "type": "module",
  "bin": {
    "arti": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "stock",
    "finance",
    "ai",
    "investment",
    "research",
    "trading"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YuqingNicole/ARTI-CLI.git"
  },
  "homepage": "https://github.com/YuqingNicole/ARTI-CLI#readme",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
