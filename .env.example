# 登录态由 `arti login` 写入配置，通常无需手动设置以下变量。
# 仅在需要覆盖默认后端/调试时使用。

# Agent / 非交互鉴权：先人工 `arti login` 一次，再 `arti token` 取出下面三个值
# 设置到 agent 环境即可免浏览器登录（token 等同密码，勿外泄、勿提交）
ARTI_AUTH_TOKEN=
ARTI_AUTH_REFRESH_TOKEN=
ARTI_AUTH_EXPIRES_AT=

# 生产函数后端（Supabase Edge Functions）
ARTI_API_URL=
ARTI_TIMEOUT=30000
ARTI_SUPABASE_URL=https://wklskhbrjnyppqfmxhxa.supabase.co
ARTI_SUPABASE_PUBLISHABLE_KEY=sb_publishable_5SIVwCD2q2QjtijkX8zn5Q_NSiocgl5
ARTI_WEB_AUTH_URL=https://www.artifin.ai/auth

# 重型研报 orchestrator 网关
ARTI_BACKEND_URL=https://api-gateway-xxx.up.railway.app
ARTI_BACKEND_ENABLED=true
ARTI_BACKEND_TIMEOUT=60000
